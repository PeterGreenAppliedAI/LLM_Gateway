# DevMesh LLM Gateway - Environment Variables
# Copy to .env and edit as needed.

# --- Server ---
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8001

# --- Database ---
# SQLite (default, zero config):
GATEWAY_DB_URL=sqlite+aiosqlite:///data/gateway.db
# PostgreSQL:
# GATEWAY_DB_URL=postgresql+asyncpg://user:pass@localhost:5432/gateway

# Store request/response bodies in audit log (privacy sensitive)
# GATEWAY_DB_STORE_REQUEST_BODY=false
# GATEWAY_DB_STORE_RESPONSE_BODY=false

# --- Guard Model (shadow security analysis) ---
# GATEWAY_GUARD_ENABLED=false
# GATEWAY_GUARD_MODEL_NAME=ibm/granite3.2-guardian:5b
# GATEWAY_GUARD_BASE_URL=http://localhost:11434
# GATEWAY_GUARD_TIMEOUT=15.0

# --- Security ---
# IPs to skip security scanning (JSON list)
# GATEWAY_SECURITY_SCAN_ALLOWLIST_IPS=["10.0.0.1"]

# --- CORS (dashboard URLs) ---
# GATEWAY_CORS_ORIGINS=["http://localhost:5174","http://192.168.1.100:5174"]

# --- API Keys (referenced in gateway.yaml) ---
# GATEWAY_KEY_APP1=your-app-key-here
# GATEWAY_KEY_DEV=your-dev-key-here

# --- Dashboard (set in dashboard/.env) ---
# VITE_API_URL=http://localhost:8001
